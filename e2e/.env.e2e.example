# Copy to .env.e2e and fill in the values you want to override.
# Everything here has a sensible default — you only need this file if the
# backend/frontend are on non-standard ports or you want to enable AI tests.

# Where the tests hit the API and the web app. Defaults match `start.bat`.
API_BASE_URL=http://127.0.0.1:8000
# Must be localhost (not 127.0.0.1) — backend CORS is pinned to this exact origin.
WEB_BASE_URL=http://localhost:3000

# When set, tests marked @pytest.mark.ai will run. Otherwise they skip.
# You do NOT need to set this to run the suite — AI tests are optional.
# ANTHROPIC_API_KEY=sk-ant-...

# Playwright browser to use for UI tests. chromium | firefox | webkit.
PW_BROWSER=chromium

# Set to 1 to run the browser visibly (for debugging). Default is headless.
PW_HEADED=0
