ANTHROPIC_API_KEY=sk-ant-your-key-here
DATABASE_URL=postgresql+asyncpg://newgen:newgen@db:5432/newgen_realty
# Optional: Market data for real comparable sales (get key from rapidapi.com)
REALTY_MOLE_API_KEY=your-rapidapi-key-here
# Optional: ATTOM Data API for prospecting engine (get key from attomdata.com)
ATTOM_API_KEY=your-attom-api-key-here
# Optional: Resend for transactional email sending (get key from resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=agent@yourdomain.com
# Optional: Twilio for SMS sending (get credentials from twilio.com/console)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
# HMAC secret for validating inbound Twilio/Resend webhooks
INBOUND_WEBHOOK_SECRET=
# Drip scheduler (defaults are fine for most setups)
SCHEDULER_ENABLED=true
SCHEDULER_TICK_SECONDS=60
